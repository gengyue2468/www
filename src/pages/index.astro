---
import Layout from "../layouts/Layout.astro";
import { PageLayout, PageHeader } from "../components/layouts";
import BlogContent from "../components/render/blog-content.astro";
import { renderMarkdown, parsePageFrontmatter } from "../lib/markdown";

import indexContent from "../contents/pages/index.md?raw";

const { frontmatter, body } = parsePageFrontmatter(indexContent);
const html = await renderMarkdown(body);
const title = frontmatter.title ?? "主页";
const description = frontmatter.description ?? frontmatter.summary ?? "";
---

<Layout title={title} description={description}>
  <PageLayout>
    <PageHeader
      title={title}
      subtitle={description}
    />
    <BlogContent html={html} />
  </PageLayout>
</Layout>
